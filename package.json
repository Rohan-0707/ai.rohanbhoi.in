{
  "name": "jalvayu-ai",
  "version": "1.0.0",
  "private": true,
  "description": "JalVayu AI — Monsoon Preparedness MVP",
  "scripts": {
    "dev": "next dev --turbo -p 2510",
    "dev:socket": "node server/server.js",
    "build": "prisma generate && next build",
    "start": "next start -p 2510",
    "start:socket": "node server/server.js",
    "lint": "eslint . --max-warnings=0",
    "test": "jest",
    "test:unit": "prisma generate && vitest run",
    "test:watch": "vitest",
    "test:coverage": "prisma generate && vitest run --coverage",
    "test:jest:watch": "jest --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "pm2:dev": "pm2 start ecosystem.dev.config.js",
    "pm2:dev:stop": "pm2 stop ecosystem.dev.config.js",
    "pm2:dev:restart": "pm2 restart ecosystem.dev.config.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.80.1",
    "dotenv": "^17.4.2",
    "mariadb": "^3.5.3",
    "next": "^15.5.0",
    "nodemailer": "^9.0.3",
    "openai": "^4.104.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.15.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.0",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.5.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "pm2": "^7.0.3",
    "postcss": "^8.5.4",
    "prisma": "^7.8.0",
    "tailwindcss": "^3.4.17",
    "ts-jest": "^29.4.11",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
