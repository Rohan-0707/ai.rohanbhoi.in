# JalVayu AI — Environment Configuration
# Copy to .env and fill in production values. Never commit .env.

# ── Database (MySQL via CloudPanel) ──────────────────────────
DATABASE_URL="mysql://monsoon:YOUR_PASSWORD@localhost:3306/monsoon"

# ── Redis / BullMQ ───────────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6379"

# ── Next.js Frontend (CloudPanel App Port: 2510) ─────────────
NEXT_PUBLIC_APP_URL="https://ai.rohanbhoi.in"
NEXT_PUBLIC_SOCKET_URL="https://ai.rohanbhoi.in"

# ── Socket.io Server (internal; proxied via nginx /socket.io) ─
SOCKET_PORT=3001
CORS_ORIGIN="https://ai.rohanbhoi.in"

# ── Admin / Security ───────────────────────────────────────────
ADMIN_SECRET="change-me-to-a-long-random-string"
# Must be exactly 32 characters for AES-256-CBC
ENCRYPTION_KEY="change-me-32-byte-aes-key-here!!"

# ── Interakt WhatsApp OTP ──────────────────────────────────────
INTERAKT_API_KEY="your-interakt-basic-auth-key-base64"
INTERAKT_OTP_TEMPLATE_NAME=otp_for_help_desk
INTERAKT_OTP_LANGUAGE_CODE=en
INTERAKT_DEFAULT_COUNTRY_CODE=+91
INTERAKT_WEBHOOK_SECRET="your-interakt-webhook-secret"

# ── Email OTP (optional SMTP — falls back to console log) ─────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@ai.rohanbhoi.in

# ── AI Provider ────────────────────────────────────────────────
OPENAI_API_KEY="your-openai-api-key"
AI_API_KEY="your-openai-api-key"
AI_MODEL="gpt-4o-mini"

# ── Google Cloud Translation (optional — enables hi/kn via Translate API) ─
# GOOGLE_TRANSLATE_API_KEY="your-google-cloud-translation-api-key"
